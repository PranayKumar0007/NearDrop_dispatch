DATABASE_URL=sqlite+aiosqlite:///./neardrop.db

# Azure Communication Services (SMS)
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_SMS_FROM_NUMBER=+15550000000

# Azure Maps (geocoding)
AZURE_MAPS_SUBSCRIPTION_KEY=

# Azure Speech Services (STT token vending)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# JWT Auth
JWT_SECRET_KEY=neardrop-change-this-in-production
JWT_ALGORITHM=HS256

# Firebase Cloud Messaging (push notifications)
# Paste the full JSON content of your Firebase service account key as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=
